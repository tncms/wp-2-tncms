<?xml version="1.0"?>
<ruleset name="WP 2 TNCMS">
    <description>WordPress Coding Standards for WP 2 TNCMS (PSR-4 / namespaced OOP plugin).</description>

    <file>wp-2-tncms.php</file>
    <file>includes</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>

    <rule ref="WordPress">
        <!--
            This plugin is namespaced, PSR-4 autoloaded OOP. The WordPress
            file-naming and class-naming sniffs assume the legacy
            `class-foo.php` / procedural layout and conflict with PSR-4, so we
            opt out of them rather than rename files or rewrite the architecture.
        -->
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>
    </rule>

    <rule ref="WordPress-Extra">
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
    </rule>

    <rule ref="WordPress-Docs"/>

    <!--
        Reserved-keyword parameter names ($namespace, $resource, $array,
        $class, $object) are intentional, descriptive parameter names in the
        service/controller layer. They are local symbols only and never collide
        with the language constructs, so this advisory sniff is excluded.
        (Allowed per release task: reserved-keyword variable-name warnings.)
    -->
    <rule ref="WordPress">
        <exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
    </rule>

    <!--
        CRITICAL: the Resource Lookup API source-key literal is exactly
        `wordpress:{resource}:{id}` (lowercase). The CapitalPDangit sniff would
        "correct" the string to `WordPress:` and break every stored source key
        and REST contract. Exclude this spelling sniff ONLY for the files that
        legitimately contain the lowercase `wordpress:` literal. The sniff stays
        active everywhere else so prose misspellings are still caught.
    -->
    <rule ref="WordPress.WP.CapitalPDangit.MisspelledInText">
        <exclude-pattern>includes/Support/SourceKey.php</exclude-pattern>
        <exclude-pattern>includes/Rest/ResolveController.php</exclude-pattern>
    </rule>

    <!--
        Advisory WordPress warnings (e.g. SlowDBQuery meta_query usage, unused
        parameters required by method signatures) are intentionally accepted and
        remain visible in PHPCS output, but they must not fail CI. Only true
        errors block the build. Security sniffs remain enabled globally.
    -->
    <config name="ignore_warnings_on_exit" value="1"/>

    <config name="testVersion" value="8.1-"/>
</ruleset>
